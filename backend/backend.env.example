# ── AI ────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_key_here
OPENAI_BASE_URL=https://models.inference.ai.azure.com

# ── Search ────────────────────────────────────────────────────────────────────
TAVILY_API_KEY=tvly-your_key_here

# ── Vector Memory (Pinecone) ──────────────────────────────────────────────────
# Get your free API key at: https://app.pinecone.io
# Free tier: 1 index, 100k vectors — more than enough
PINECONE_API_KEY=pcsk_your_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/mindall.db

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-this-to-a-random-string-before-deploying
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=48

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=False

# ── CORS — comma-separated frontend URLs ─────────────────────────────────────
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173
